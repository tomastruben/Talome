{
  "mcpServers": {
    "talome": {
      "type": "stdio",
      "command": "apps/core/mcp-launch.sh",
      "args": [],
      "env": {
        "DATABASE_PATH": "apps/core/data/talome.db",
        "NODE_ENV": "production"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    }
  }
}
