# ── Secrets ──────────────────────────────────────────────────────────────────
# 64-character hex string. Encrypts session cookies and stored API keys.
# If unset in production, the server refuses to start. Generate with:
#   openssl rand -hex 32
TALOME_SECRET=

# ── LLM API Keys ─────────────────────────────────────────────────────────────
# You only need one of these. ANTHROPIC_API_KEY is recommended.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default provider
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514

# ── Docker ───────────────────────────────────────────────────────────────────
# Socket path. Linux default is /var/run/docker.sock. See commented paths for
# macOS runtimes.
DOCKER_SOCKET=/var/run/docker.sock
# macOS + OrbStack:    /Users/$USER/.orbstack/run/docker.sock
# macOS + Docker Desktop: /var/run/docker.sock (usually auto-forwarded)

# ── Talome Core ──────────────────────────────────────────────────────────────
CORE_PORT=4000
CORE_HOST=0.0.0.0

# ── Dashboard ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CORE_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Talome
NEXT_PUBLIC_DASHBOARD_BENTO=1
NEXT_PUBLIC_DECLARATIVE_WIDGETS=1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/talome.db

# ── Security ─────────────────────────────────────────────────────────────────
# Origin allowlist for CSRF/CORS. Loopback and RFC1918 are always trusted.
# Add public hostnames here only if you deliberately expose Talome behind
# HTTPS on a public address (comma-separated).
# DASHBOARD_ORIGIN=https://talome.example.com

# Terminal daemon bind address. Default 127.0.0.1 so only the main server
# (on the same host) can reach the PTY. Do not change unless you understand
# the implications.
# TERMINAL_DAEMON_HOST=127.0.0.1

# ── Feature flags ────────────────────────────────────────────────────────────
# Custom AI-authored tools execute arbitrary TypeScript in-process with no
# sandbox. Disabled by default. Set to "true" only if you are willing to
# treat custom tools like code you are willingly running on your server.
# TALOME_ENABLE_CUSTOM_TOOLS=false

# ── Backups ──────────────────────────────────────────────────────────────────
# Where automatic SQLite snapshots are written. Defaults to ~/.talome/backups/
# on native installs, or /app/backups (backed by a named volume) in Docker.
# TALOME_BACKUP_DIR=

# Snapshot interval in milliseconds. Default 24h.
# TALOME_SELF_BACKUP_INTERVAL_MS=86400000

# Number of snapshots to retain (oldest are pruned). Default 7.
# TALOME_SELF_BACKUP_KEEP=7

# Disable self-backup entirely. Not recommended.
# TALOME_SELF_BACKUP_DISABLED=false
