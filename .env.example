# LLM API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default provider
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514

# Docker
DOCKER_SOCKET=/var/run/docker.sock
# macOS + OrbStack: /Users/$USER/.orbstack/run/docker.sock

# Talome Core
CORE_PORT=4000
CORE_HOST=0.0.0.0

# Dashboard
NEXT_PUBLIC_CORE_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Talome
NEXT_PUBLIC_DASHBOARD_BENTO=1
NEXT_PUBLIC_DECLARATIVE_WIDGETS=1

# Database
DATABASE_PATH=./data/talome.db

